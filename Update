local UserInputService = game:GetService("UserInputService")

local isMobile = UserInputService.TouchEnabled and not UserInputService.MouseEnabled
local isPC = UserInputService.MouseEnabled and not UserInputService.TouchEnabled

if isMobile then
    print("You User Mobile [Attached] [Mobile Support]")
    wait(1)
    loadstring(game:HttpGet("https://raw.githubusercontent.com/Zyptrue/Main-Scripts/refs/heads/main/Main%20Scripts%20%5BV1%5D"))()
elseif isPC then
    print("You User PC [Attached] [PC Support]")
    wait(1)
    loadstring(game:HttpGet("https://raw.githubusercontent.com/Zyptrue/Release/refs/heads/main/New%20Interface"))()
end
